# syntax=docker/dockerfile:1.6
# ----------------------------------------------------------------------
# Stage 1: Go toolchain — build api, worker, ct-to-timesketch, and the
# Linux/macOS collectors (all separate modules) in a single layer.
# ct-to-timesketch's go.mod requires Go 1.26, so we use that everywhere.
# ----------------------------------------------------------------------
FROM golang:1.26-alpine AS builder

RUN apk add --no-cache gcc musl-dev git

WORKDIR /src

COPY backend/ ./backend/
COPY ct-to-timesketch/ ./ct-to-timesketch/
COPY collector-linux/ ./collector-linux/
COPY collector-macos/ ./collector-macos/

RUN cd backend \
    && go mod download \
    && CGO_ENABLED=0 go build -trimpath -ldflags "-s -w" -o /out/responseray-api ./cmd/api/ \
    && CGO_ENABLED=0 go build -trimpath -ldflags "-s -w" -o /out/responseray-worker ./cmd/worker/

RUN cd ct-to-timesketch \
    && go mod download \
    && CGO_ENABLED=1 go build -trimpath -ldflags "-s -w" -o /out/ct-to-timesketch ./cmd/ct-to-timesketch

RUN cd collector-linux \
    && go mod download \
    && CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build \
        -trimpath -ldflags "-s -w" \
        -o /out/collectors/linux/responseray-collector-linux \
        ./cmd/responseray-collector-linux

RUN cd collector-macos \
    && go mod download \
    && CGO_ENABLED=0 GOOS=darwin GOARCH=amd64 go build \
        -trimpath -ldflags "-s -w" \
        -o /out/collectors/macos/responseray-collector-macos \
        ./cmd/responseray-collector-macos

# ----------------------------------------------------------------------
# Stage 2: build the Windows .NET collector as a self-contained single-file exe.
# ----------------------------------------------------------------------
FROM mcr.microsoft.com/dotnet/sdk:8.0 AS collectors-windows

WORKDIR /src
COPY collector/src/ResponseRayCollector/ ./ResponseRayCollector/

RUN cd ResponseRayCollector \
    && dotnet publish -c Release -r win-x64 --self-contained true \
        /p:PublishSingleFile=true \
        /p:PublishTrimmed=false \
        -o /out

# ----------------------------------------------------------------------
# Stage 3: final runtime image.
# ----------------------------------------------------------------------
FROM alpine:3.19

RUN apk add --no-cache ca-certificates tzdata

# API + worker
COPY --from=builder /out/responseray-api /usr/local/bin/
COPY --from=builder /out/responseray-worker /usr/local/bin/

# ct-to-timesketch + cloudrules (auto-detected from <exe-dir>/cloudrules/)
COPY --from=builder /out/ct-to-timesketch /usr/local/bin/ct-to-timesketch
COPY ct-to-timesketch/cloudrules/ /usr/local/bin/cloudrules/

# Collector payloads served via /api/collectors/<platform>/download.
# Linux/macOS ship as tar.gz bundles (binary + INSTALL.txt) so the OS
# recognizes the file type and exec bits survive the round-trip.
# Windows ships as a bare .exe, ESXi as a .sh.
RUN mkdir -p /usr/share/responseray/collectors/windows \
             /usr/share/responseray/collectors/linux \
             /usr/share/responseray/collectors/macos \
             /usr/share/responseray/collectors/esxi \
             /tmp/pkg/responseray-collector-linux \
             /tmp/pkg/responseray-collector-macos

COPY --from=builder /out/collectors/linux/responseray-collector-linux \
     /tmp/pkg/responseray-collector-linux/responseray-collector-linux
COPY --from=builder /out/collectors/macos/responseray-collector-macos \
     /tmp/pkg/responseray-collector-macos/responseray-collector-macos
COPY collector-linux/INSTALL.txt /tmp/pkg/responseray-collector-linux/INSTALL.txt
COPY collector-macos/INSTALL.txt /tmp/pkg/responseray-collector-macos/INSTALL.txt

RUN chmod 0755 /tmp/pkg/responseray-collector-linux/responseray-collector-linux \
               /tmp/pkg/responseray-collector-macos/responseray-collector-macos \
    && tar -C /tmp/pkg -czf \
        /usr/share/responseray/collectors/linux/responseray-collector-linux.tar.gz \
        responseray-collector-linux \
    && tar -C /tmp/pkg -czf \
        /usr/share/responseray/collectors/macos/responseray-collector-macos.tar.gz \
        responseray-collector-macos \
    && rm -rf /tmp/pkg

COPY --from=collectors-windows /out/ResponseRayCollector.exe \
     /usr/share/responseray/collectors/windows/ResponseRayCollector.exe
COPY collector-esxi/responseray-collector-esxi.sh \
     /usr/share/responseray/collectors/esxi/responseray-collector-esxi.sh

RUN chmod 0755 /usr/local/bin/ct-to-timesketch \
               /usr/share/responseray/collectors/esxi/responseray-collector-esxi.sh

RUN mkdir -p /data/uploads /data/artifacts /data/reports

EXPOSE 8080

CMD ["sh", "-c", "responseray-worker & responseray-api"]
